{
  "name": "claude-agents-monitor",
  "version": "0.1.0",
  "description": "Real-time dashboard for monitoring active Claude Code agents and subagents",
  "type": "module",
  "bin": {
    "claude-agents-monitor": "./bin/claude-agents-monitor.mjs"
  },
  "files": [
    "bin/",
    "server/",
    "src/",
    "dist/",
    "index.html",
    "postcss.config.js",
    "tailwind.config.js",
    "tsconfig.json",
    "tsconfig.server.json",
    "vite.config.ts"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"tsx watch server/index.ts\" \"vite\"",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "preview": "npm run build && npm start",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "agents",
    "monitor",
    "dashboard",
    "ai",
    "llm",
    "anthropic",
    "devtools"
  ],
  "author": "Konstantinos Tsolakidis",
  "homepage": "https://github.com/tsolman/claude-agents-monitor",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tsolman/claude-agents-monitor.git"
  },
  "bugs": {
    "url": "https://github.com/tsolman/claude-agents-monitor/issues"
  },
  "dependencies": {
    "express": "^4.21.0",
    "tsx": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "license": "MIT"
}
